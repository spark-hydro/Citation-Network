# ⚠️ This file is a template. Copy it, rename it to '.env', and fill in the details.
# NEVER upload your '.env' file to GitHub! (It is already ignored via .gitignore)

# ==============================================================================
# 🔴 REQUIRED SETTINGS
# ==============================================================================

# Zotero User ID (Find "Your userID for API calls is XXXXXX" at https://www.zotero.org/settings/keys)
ZOTERO_USER_ID=

# Zotero API Key (Create via "Create new private key" at https://www.zotero.org/settings/keys)
ZOTERO_API_KEY=

# Absolute path to your Obsidian vault folder (e.g., C:\Users\YourName\Documents\ObsidianVault)
OBSIDIAN_VAULT_PATH=

# ==============================================================================
# 🟢 OPTIONAL SETTINGS (Have default values or are optional features)
# ==============================================================================

# Zotero Library Type (Use 'user' for personal library, 'group' for group library)
# Default: user
ZOTERO_LIBRARY_TYPE=user

# Folder name where notes will be created within the Obsidian vault
# Default: Citation Network
CITATION_NETWORK_FOLDER=Citation Network

# OpenAlex Polite Pool Email
# Providing your email address allows you to query the OpenAlex API using their 'polite pool' for faster response times.
OPENALEX_EMAIL=
