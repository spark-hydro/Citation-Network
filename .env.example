# ⚠️ 이 파일은 템플릿입니다. 복사해서 '.env' 파일로 이름을 바꾼 뒤 정보를 기입해 주세요.
# 절대 '.env' 파일을 GitHub에 업로드하지 마세요! (.gitignore에 이미 등록되어 있습니다)

# 1. Zotero 설정
# Zotero User ID (https://www.zotero.org/settings/keys 에서 "Your userID for API calls is XXXXXX" 확인)
ZOTERO_USER_ID=

# Zotero API Key (https://www.zotero.org/settings/keys 에서 "Create new private key"로 생성)
ZOTERO_API_KEY=

# 라이브러리 타입 (개인 라이브러리는 user, 그룹 라이브러리는 group)
ZOTERO_LIBRARY_TYPE=user

# 2. Obsidian 설정
# Obsidian 볼트 폴더의 절대 경로 (예: C:\Users\YourName\Documents\ObsidianVault)
OBSIDIAN_VAULT_PATH=

# 볼트 내에서 노트가 생성될 폴더명 (기본값: Citation Network)
CITATION_NETWORK_FOLDER=Citation Network

# 3. OpenAlex 설정 (선택 사항)
# 이메일 주소를 적으면 OpenAlex의 'polite pool'을 통해 더 빠른 속도로 API를 호출할 수 있습니다.
OPENALEX_EMAIL=
